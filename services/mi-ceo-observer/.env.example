# Mi CEO Observer — Session A (CEO Main Account)
# Copy to .env and fill in values

# Mi-Core connection
MI_CORE_URL=http://localhost:4001
MI_CORE_API_KEY=           # same as server/.env MI_CORE_API_KEY

# Session storage (ISOLATED from Session B / whatsapp-ai-gateway)
CEO_SESSION_ROOT=./data/ceo-session
CEO_CLIENT_ID=mi-ceo-observer

# Headless browser
WHATSAPP_HEADLESS=false
PUPPETEER_EXECUTABLE_PATH=

# Observer settings
OBSERVER_PORT=3212
OBSERVE_PRIVATE_CHATS=true
OBSERVE_GROUPS=true

# Whitelist — only process messages from these group IDs / contact IDs
# Comma-separated @c.us or @g.us IDs. Empty = observe all CEO conversations.
ALLOWED_CHAT_IDS=

# Task detection sensitivity (1=conservative, 3=aggressive)
TASK_DETECTION_SENSITIVITY=2

# CEO phone (for identity — messages FROM this account are self-messages)
CEO_PHONE=

# Log level
LOG_LEVEL=info
