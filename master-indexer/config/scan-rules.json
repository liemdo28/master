{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "**/*.py",
    "**/*.java",
    "**/*.cs",
    "**/*.go",
    "**/*.rs",
    "**/*.md",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml",
    "**/*.sql",
    "**/*.sh",
    "**/*.ps1",
    "**/*.bat"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/coverage/**",
    "**/.nyc_output/**",
    "**/.pytest_cache/**",
    "**/__pycache__/**",
    "**/venv/**",
    "**/.venv/**",
    "**/bin/**",
    "**/obj/**",
    "**/target/**",
    "**/.idea/**",
    "**/.vscode/**",
    "**/_archive/**",
    "**/*.zip",
    "**/*.log",
    "**/*.tmp"
  ],
  "projectMarkers": [
    ".git",
    "package.json",
    "pyproject.toml",
    "go.mod",
    "Cargo.toml",
    "*.csproj",
    "pom.xml",
    "build.gradle"
  ]
}
