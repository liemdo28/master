{
  "$schema": "Agent OS Task Contract v1.0",
  "description": "Defines the task object structure shared between Control Plane and Workers",
  "task": {
    "id": { "type": "string", "format": "uuid", "description": "Unique task identifier" },
    "type": { "type": "string", "enum": ["build", "qa", "git_sync", "audit", "script"], "description": "Task type" },
    "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "cancelled", "waiting_approval"], "description": "Current status" },
    "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"], "default": "medium" },
    "project": { "type": "string", "description": "Project path or identifier" },
    "createdBy": { "type": "string", "default": "ceo", "description": "Who created the task" },
    "workerId": { "type": "string", "nullable": true, "description": "Assigned worker ID" },
    "payload": { "type": "object", "description": "Task-specific data (command, gitAction, app, etc.)" },
    "createdAt": { "type": "string", "format": "date-time" },
    "startedAt": { "type": "string", "format": "date-time", "nullable": true },
    "completedAt": { "type": "string", "format": "date-time", "nullable": true },
    "error": { "type": "string", "nullable": true }
  },
  "approval": {
    "id": { "type": "string", "format": "uuid" },
    "taskId": { "type": "string", "format": "uuid" },
    "riskLevel": { "type": "string", "enum": ["safe", "elevated", "dangerous", "critical"] },
    "status": { "type": "string", "enum": ["auto_approved", "pending", "approved", "denied"] },
    "requestedBy": { "type": "string" },
    "approvedBy": { "type": "string", "nullable": true },
    "deniedBy": { "type": "string", "nullable": true },
    "reason": { "type": "string", "nullable": true },
    "createdAt": { "type": "string", "format": "date-time" },
    "resolvedAt": { "type": "string", "format": "date-time", "nullable": true }
  },
  "riskClassification": {
    "safe": ["audit", "git status", "git log", "git diff", "open app", "run qa", "build", "start api proxy"],
    "elevated": ["git push", "git pull", "deploy staging", "run script"],
    "dangerous": ["deploy production", "delete files", "send email"],
    "critical": ["dns change", "database migration", "cloudflare change"]
  },
  "api": {
    "chat": {
      "POST /api/chat": { "body": { "message": "string" }, "response": { "messages": "array", "task": "object" } },
      "GET /api/chat/history": { "query": { "limit": "number" }, "response": { "messages": "array" } },
      "POST /api/chat/approve": { "body": { "taskId": "string" }, "response": { "success": "boolean" } },
      "POST /api/chat/deny": { "body": { "taskId": "string", "reason": "string?" }, "response": { "success": "boolean" } },
      "GET /api/chat/pending": { "response": { "approvals": "array" } }
    },
    "tasks": {
      "GET /api/tasks": { "query": { "status": "string?" }, "response": { "tasks": "array" } },
      "POST /api/tasks": { "body": { "type": "string", "project": "string", "priority": "string?", "payload": "object?" }, "response": { "task": "object" } },
      "GET /api/tasks/:id": { "response": { "task": "object" } },
      "POST /api/tasks/:id/cancel": { "response": { "success": "boolean" } },
      "POST /api/tasks/:id/retry": { "response": { "task": "object" } },
      "GET /api/tasks/:id/logs": { "response": { "logs": "array" } },
      "GET /api/tasks/:id/artifacts": { "response": { "artifacts": "array" } }
    },
    "kill": {
      "POST /api/kill/task/:id": { "response": { "success": "boolean", "message": "string" } },
      "POST /api/kill/worker/:id": { "response": { "success": "boolean", "message": "string" } },
      "POST /api/kill/all": { "response": { "success": "boolean", "killedTasks": "number", "stoppedWorkers": "number" } }
    },
    "workers": {
      "GET /api/workers": { "response": { "workers": "array" } },
      "POST /api/workers/register": { "body": { "name": "string", "hostname": "string", "tailscaleIp": "string" }, "response": { "worker": "object" } },
      "POST /api/workers/:id/heartbeat": { "body": { "token": "string", "status": "string", "systemInfo": "object" } }
    },
    "system": {
      "GET /api/health": { "response": { "status": "string", "uptime": "number" } },
      "GET /api/stats": { "response": { "totalTasks": "number", "pendingTasks": "number", "runningTasks": "number" } }
    }
  }
}
