MI_PORT=4001
AI_SERVICE_URL=http://localhost:4002
AGENT_ENGINE_URL=http://127.0.0.1:4003
OLLAMA_URL=http://localhost:11434
OLLAMA_FAST_MODEL=qwen3:8b
OLLAMA_DEEP_MODEL=qwen3:14b
MASTER_ROOT=E:/Project/Master
ALLOWED_ORIGINS=http://localhost:4001,http://localhost:3000

# Mobile PIN auth (leave blank = no auth, dev mode)
# MI_PIN=1234

# ── Global cache dir ───────────────────────────────────────────────────────
GLOBAL_DIR=E:/Project/Master/.local-agent-global

# ── Project connector paths ────────────────────────────────────────────────
# Local projects (override defaults)
RAW_WEBSITE_ROOT=E:/Project/Master/RawSushi/RawWebsite
BAKUDAN_WEBSITE_ROOT=E:/Project/Master/Bakudan/bakudanramen.com-current
DASHBOARD_ROOT=E:/Project/Master/Bakudan/dashboard.bakudanramen.com
ACCOUNTING_DB=E:/Project/Master/accounting-engine/ledgers/accounting.db
FOOD_SAFETY_ROOT=E:/Project/Master/food-safety-gateway

# ── Remote agent config ────────────────────────────────────────────────────
# Deploy mi-remote-agent on the remote machine and set these:
MI_REMOTE_TOKEN=change-me-to-a-strong-random-token

# Integration System (remote machine)
INTEGRATION_SYSTEM_HOST=
INTEGRATION_SYSTEM_PORT=4005

# WhatsApp AI Gateway (remote machine)
WHATSAPP_HOST=
WHATSAPP_PORT=4005

# ── Accounting engine (local API) ──────────────────────────────────────────
