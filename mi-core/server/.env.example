MI_PORT=4001
AI_SERVICE_URL=http://localhost:4002
AGENT_ENGINE_URL=http://127.0.0.1:4003
OLLAMA_URL=http://localhost:11434
OLLAMA_FAST_MODEL=qwen3:8b
OLLAMA_DEEP_MODEL=qwen3:14b
OLLAMA_TINY_MODEL=qwen3:1.7b
OLLAMA_CODER_MODEL=qwen2.5-coder:7b

# ── Brain Router (WS1) ─────────────────────────────────────────────────────
# Optional: Claude API for complex reasoning / engineering tasks
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Qdrant Semantic Memory (WS6) ───────────────────────────────────────────
# Start with: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
# QDRANT_URL=http://localhost:6333

# ── Browser Agent (WS8) ────────────────────────────────────────────────────
# Setup: pip install playwright && playwright install chromium
# DASHBOARD_URL=https://dashboard.bakudanramen.com
MASTER_ROOT=E:/Project/Master
ALLOWED_ORIGINS=http://localhost:4001,http://localhost:3000

# Mobile PIN auth (leave blank = no auth, dev mode)
# MI_PIN=1234

# ── Global cache dir ───────────────────────────────────────────────────────
GLOBAL_DIR=E:/Project/Master/.local-agent-global

# ── Project connector paths ────────────────────────────────────────────────
# Local projects (override defaults)
RAW_WEBSITE_ROOT=E:/Project/Master/RawSushi/RawWebsite
BAKUDAN_WEBSITE_ROOT=E:/Project/Master/Bakudan/bakudanramen.com-current
DASHBOARD_ROOT=E:/Project/Master/Bakudan/dashboard.bakudanramen.com
ACCOUNTING_DB=E:/Project/Master/accounting-engine/ledgers/accounting.db
FOOD_SAFETY_ROOT=E:/Project/Master/food-safety-gateway

# ── Remote agent config ────────────────────────────────────────────────────
# Deploy mi-remote-agent on the remote machine and set these:
MI_REMOTE_TOKEN=change-me-to-a-strong-random-token

# Integration System (remote machine)
INTEGRATION_SYSTEM_HOST=
INTEGRATION_SYSTEM_PORT=4005

# WhatsApp AI Gateway (remote machine)
WHATSAPP_HOST=
WHATSAPP_PORT=4005

# ── Accounting engine (local API) ──────────────────────────────────────────
ACCOUNTING_API_URL=http://127.0.0.1:8844

# ── Dashboard (Dreamhost live API) ────────────────────────────────────────
# DASHBOARD_API=http://dashboard.bakudanramen.com

# ── Google OAuth (do not commit downloaded client_secret_*.json files) ────
# Create an OAuth client in Google Cloud Console and copy values here.
# Required for Gmail, Calendar, Drive, Contacts, and Google Sheet reporting.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4001/api/auth/google/callback

# Optional: only for legacy sheet reporter OAuth fallback.
# Prefer authorizing via /api/auth/google/start so refresh tokens are stored locally.
GOOGLE_REFRESH_TOKEN=

# ── Big Data Foundation (PostgreSQL + MinIO + Qdrant) ─────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mi_bigdata
POSTGRES_USER=mi_user
POSTGRES_PASSWORD=changeme

MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=mi_minio
MINIO_ROOT_PASSWORD=changeme

# QDRANT_URL=http://localhost:6333
