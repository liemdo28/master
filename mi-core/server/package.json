{
  "name": "mi-core-server",
  "version": "1.0.0",
  "description": "Mi Ultimate — Executive OS Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "auth:create-pin-hash": "node scripts/create-pin-hash.js",
    "bigdata:up": "cd ../infra/bigdata && docker-compose up -d",
    "bigdata:down": "cd ../infra/bigdata && docker-compose down",
    "bigdata:health": "node ../scripts/bigdata-health-check.js",
    "bigdata:sample": "node ../scripts/bigdata-ingest-sample.js",
    "bigdata:quality": "node ../scripts/bigdata-run-quality-checks.js",
    "bigdata:search": "node ../scripts/bigdata-search.js",
    "bigdata:export": "node ../scripts/bigdata-export-report.js",
    "bigdata:test": "tsx src/bigdata/bigdata.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@googleapis/calendar": "^15.0.0",
    "@googleapis/gmail": "^17.0.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.12.0",
    "playwright": "^1.61.1",
    "uuid": "^11.1.1",
    "ws": "^8.18.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
