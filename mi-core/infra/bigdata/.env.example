# Mi Big Data Infrastructure — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# PostgreSQL
POSTGRES_DB=mi_bigdata
POSTGRES_USER=mi_user
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# MinIO (S3-compatible object store)
MINIO_ROOT_USER=mi_minio
MINIO_ROOT_PASSWORD=changeme_strong_password_here
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_RAW=mi-raw
MINIO_BUCKET_REPORTS=mi-reports
MINIO_BUCKET_EVIDENCE=mi-evidence

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Big Data API (consumed by Mi-Core server)
BIGDATA_ENABLED=true
BIGDATA_LOG_LEVEL=info
