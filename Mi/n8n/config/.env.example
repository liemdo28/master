# ─────────────────────────────────────────────────────────────────────────────
# Mi Automation Fabric — n8n Environment Variables (.env.example)
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# n8n Server
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_LOG_LEVEL=info
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

# n8n Authentication (REQUIRED)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=CHANGE_ME_admin_user
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_password_min_16_chars

# n8n Encryption Key (REQUIRED — rotate to a 32+ char random string)
N8N_ENCRYPTION_KEY=CHANGE_ME_32_char_random_encryption_key

# n8n Webhook Base URL (publicly reachable URL for n8n webhooks)
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# Database (SQLite default; for production use PostgreSQL)
N8N_DB_TYPE=sqlite
N8N_DB_SQLITE_DATABASE=/home/node/.n8n/database.sqlite
# PostgreSQL example (uncomment and configure for production):
# DB_POSTGRESDB_HOST=localhost
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n
# DB_POSTGRESDB_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Mi-Core Integration (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────

# URL where Mi-Core is reachable from the n8n host
# - When n8n runs in Docker:  http://host.docker.internal:4001
# - When n8n runs natively:  http://127.0.0.1:4001
MI_CORE_URL=http://127.0.0.1:4001

# API key for Mi-Core (configure in Mi-Core .env as MI_CORE_API_KEY)
MI_API_KEY=CHANGE_ME_match_Mi_Core_MI_CORE_API_KEY

# Webhook where n8n posts evidence after each workflow run
MI_EVIDENCE_WEBHOOK=http://127.0.0.1:4001/api/n8n/evidence

# ─────────────────────────────────────────────────────────────────────────────
# Brand & Routing Defaults
# ─────────────────────────────────────────────────────────────────────────────

# Default brand when workflow receives no brand_id
MI_DEFAULT_BRAND=bakudan

# Default location when workflow receives no location_id
MI_DEFAULT_LOCATION=all

# ─────────────────────────────────────────────────────────────────────────────
# Operational
# ─────────────────────────────────────────────────────────────────────────────

# Logs
N8N_LOG_OUTPUT=file
N8N_LOG_FILE_LOCATION=/home/node/.n8n/logs/n8n.log
