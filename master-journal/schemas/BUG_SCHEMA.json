{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Master Journal Bug",
  "description": "Schema for bug records in the Master Journal",
  "type": "object",
  "required": ["id", "timestamp", "project", "title", "severity", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^bug_[a-z0-9_]+$",
      "description": "Unique bug identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "investigating", "fixing", "fixed", "verified", "closed", "wontfix"]
    },
    "symptoms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "root_cause": {
      "type": "string"
    },
    "affected_versions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "first_occurrence": {
      "type": "string",
      "format": "date"
    },
    "reported_by": { "type": "string" },
    "assigned_to": { "type": "string" },
    "fix": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "applied_at": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["pending", "applied", "verified"] }
      }
    },
    "prevention": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_incidents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "links": {
      "type": "object",
      "properties": {
        "decision": { "type": "string" },
        "journal_event": { "type": "string" }
      }
    }
  }
}
