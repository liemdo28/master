{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Master Journal Decision",
  "description": "Schema for decision records in the Master Journal",
  "type": "object",
  "required": ["id", "timestamp", "project", "title", "decision", "rationale", "decided_by"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^dec_[a-z0-9]{12}$",
      "description": "Unique decision identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "description": "Short title of the decision"
    },
    "decision": {
      "type": "string",
      "description": "What was decided"
    },
    "alternatives_considered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rationale": {
      "type": "string",
      "description": "Why this decision was made"
    },
    "risk_assessment": {
      "type": "object",
      "properties": {
        "risk": { "type": "string" },
        "mitigation": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
      }
    },
    "rollback_plan": {
      "type": "string",
      "description": "How to reverse this decision if needed"
    },
    "decided_by": { "type": "string" },
    "approved_by": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["proposed", "approved", "rejected", "superseded"]
    },
    "links": {
      "type": "object",
      "properties": {
        "journal_event": { "type": "string" },
        "implementation_task": { "type": "string" },
        "related_decisions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
