# ══════════════════════════════════════════════════════════════════════════════
# Mi-Core Central Command — Environment Variables
# Copy to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
MI_PORT=4001
HOST=127.0.0.1
# Set to 1 to bind 0.0.0.0 (LAN + Tailscale access from iPhone/Mac)
MOBILE_ACCESS=0
# Comma-separated allowed CORS origins (beyond localhost)
ALLOWED_ORIGINS=http://localhost:4001,http://127.0.0.1:4001

# ── Paths ─────────────────────────────────────────────────────────────────────
MI_CORE_ROOT=E:/Project/Master/mi-core
GLOBAL_DIR=E:/Project/Master/.local-agent-global
MASTER_ROOT=E:/Project/Master
DASHBOARD_ROOT=E:/Project/Master/Bakudan/dashboard.bakudanramen.com
DASHBOARD_URL=http://dashboard.bakudanramen.com

# ── Multi-Node ────────────────────────────────────────────────────────────────
MI_NODE_ID=mi-core-primary
# Set on secondary devices: MI_NODE_ID=mi-laptop-1

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_API_BASE_URL=http://localhost:3211
WHATSAPP_HOST=localhost
WHATSAPP_PORT=3211
# CEO WhatsApp number (E.164 format: +1234567890@s.whatsapp.net)
CEO_WHATSAPP_NUMBER=
# Comma-separated allowed sender numbers (same format)
CEO_WHATSAPP_ALLOWED_NUMBERS=
# Internal IDs for CEO (used for routing, can be same as allowed numbers)
MI_CEO_WHATSAPP_IDS=

# ── Security ──────────────────────────────────────────────────────────────────
# PIN for Mi authentication (plain text OR hash below)
MI_PIN=
MI_PIN_HASH=
# Remote access token (used by mobile app)
MI_REMOTE_TOKEN=
# Review/approval system internal auth token
REVIEW_SYSTEM_INTERNAL_TOKEN=
REVIEW_APPROVAL_INTERNAL_TOKEN=
REVIEW_APPROVAL_TIMEOUT_MINUTES=1440

# ── AI Providers ──────────────────────────────────────────────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small

# Ollama (local LLM — no key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FAST_MODEL=llama3.2
OLLAMA_DEEP_MODEL=llama3.1:70b
OLLAMA_CODER_MODEL=deepseek-coder-v2
OLLAMA_TINY_MODEL=qwen2.5:0.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# DeepSeek
DEEPSEEK_MODEL=deepseek-chat

# Gemini
GEMINI_MODEL=gemini-1.5-flash

# MiniMax
MINIMAX_MODEL=abab6.5s-chat

# OpenAI-Compatible (any provider with OpenAI API)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

# Provider routing (ordered preference for text/embed)
MI_TEXT_PROVIDER_ORDER=ollama,anthropic,openai
MI_EMBED_PROVIDER_ORDER=ollama,openai
# Set to 1 to allow cloud AI fallback when local fails
ALLOW_CLOUD_AI=0
ALLOW_CLOUD_FALLBACK=0

# ── Google ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4001/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=
# Path to service account JSON (for Drive/Sheets without OAuth)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Google Sheet ID for food safety / reporting
GOOGLE_SHEET_ID=

# ── Asana ─────────────────────────────────────────────────────────────────────
ASANA_TOKEN=
# Workspace GID (from asana.com/0/settings/api)
# ASANA_WORKSPACE_GID=

# ── PostgreSQL (queue, analytics) ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mi_core
POSTGRES_DATABASE=mi_core
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=mi-core
MINIO_BUCKET_EVIDENCE=evidence
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_REPORTS=reports

# ── Qdrant (vector search) ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_COLLECTION=mi_knowledge

# ── Knowledge ─────────────────────────────────────────────────────────────────
# Comma-separated root dirs to index into knowledge base
KNOWLEDGE_INDEX_ROOTS=E:/Project/Master/mi-core/docs,E:/Project/Master/mi-core/reports
KNOWLEDGE_MAX_INDEX_DOCS=5000
KNOWLEDGE_MAX_TEXT_BYTES=50000
# Set to 1 to ingest knowledge DB on server boot
MI_BOOT_KNOWLEDGE_INGEST=0

# ── Jarvis / Monitoring ───────────────────────────────────────────────────────
# Proactive monitor check interval (minutes)
JARVIS_MONITOR_INTERVAL_MIN=15

# ── Integration System ────────────────────────────────────────────────────────
INTEGRATION_SYSTEM_HOST=localhost
INTEGRATION_SYSTEM_PORT=3211

# ── Review System ─────────────────────────────────────────────────────────────
REVIEW_SYSTEM_BASE_URL=http://localhost:4001
REVIEW_DATA_DIR=E:/Project/Master/.local-agent-global/review-data

# ── Agent Coding API Keys ─────────────────────────────────────────────────────
AGENT_CODING_API_KEY=
AGENT_ENGINE_URL=http://localhost:4003

# ── Voice ────────────────────────────────────────────────────────────────────
VOICE_TTS_ENABLED=0
WHISPER_MODEL=base
WHISPER_LANG=vi

# ── External Services ─────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:4001
SKYVERN_API_KEY=
SKYVERN_BASE_URL=http://localhost:8000

# ── Data paths ────────────────────────────────────────────────────────────────
QB_DB_PATH=E:/Project/Master/.local-agent-global/qb-agent.db
QB_LOG_DIR=E:/Project/Master/.local-agent-global/qb-logs
MI_DATA_DIR=E:/Project/Master/.local-agent-global
MI_OWNER_PROFILE_PATH=E:/Project/Master/.local-agent-global/owner-profile.json
MI_REFERENCE_BRAIN_PATH=E:/Project/Master/.local-agent-global/reference-brain.json
ACCOUNTING_DB_PATH=E:/Project/Master/.local-agent-global/accounting.db
ACCOUNTING_URL=http://localhost:4001
FOOD_SAFETY_ROOT=E:/Project/Master/.local-agent-global/food-safety
BAKUDAN_WEBSITE_ROOT=E:/Project/Master/bakudanramen.com
RAW_WEBSITE_ROOT=E:/Project/Master/rawsushibar.com
BROWSER_EVIDENCE_DIR=E:/Project/Master/.local-agent-global/browser-evidence
DASHBOARD_PATH=E:/Project/Master/Bakudan/dashboard.bakudanramen.com
DASHBOARD_API=http://localhost:4001
DASHBOARD_API_URL=http://localhost:4001

# Sprint 6.1: Data at Rest Encryption
ENCRYPTION_KEY=
# Generate key: node fix-env.js --gen
