{
  "name": "master-audit-package-exporter",
  "version": "2.0.0",
  "description": "CEO Directive - Master Audit Package Exporter for Agent OS",
  "main": "export-master-audit-package.js",
  "scripts": {
    "export": "node export-master-audit-package.js",
    "export:build": "node export-master-audit-package.js --reason \"after-build\"",
    "export:manual": "node export-master-audit-package.js --reason \"manual-ceo-request\"",
    "export:scheduler": "node export-scheduler.js",
    "export:scheduler:once": "node export-scheduler.js --once",
    "export:lifecycle": "node lifecycle-trigger.js --event",
    "export:status": "node -e \"console.log(JSON.stringify(require('./export-scheduler.js').getStatus(), null, 2))\""
  },
  "keywords": ["agent-os", "audit", "export", "ceo"],
  "author": "CEO Office",
  "license": "MIT"
}
