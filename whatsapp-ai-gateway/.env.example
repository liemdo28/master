# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_group_chat_id_here

# ── AI ────────────────────────────────────────────────────
AI_ENABLED=true

# ── Business Hours ────────────────────────────────────────
# Set to false to disable the business-hours guard (always reply)
BUSINESS_HOURS_ENABLED=true

# ── Rate Limiting ─────────────────────────────────────────
RATE_WINDOW_MS=300000          # 5 minutes
RATE_MAX_MESSAGES=10           # soft limit — stop auto-reply, still forward to Telegram
RATE_BLOCK_MESSAGES=30         # hard limit — ignore completely

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_PORT=3210
DASHBOARD_HOST=0.0.0.0

# ── WhatsApp Session ──────────────────────────────────────
SESSION_DIR=./data/session
AUTO_RECONNECT=true

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── Food Safety AI (Phase 3) ─────────────────────────────
# Enable/disable the entire food safety module
FOOD_SAFETY_ENABLED=false

# Always true during dev/test — set to false only after test chat passes
FOOD_SAFETY_TEST_MODE=true

# Google Sheet URL — leave empty to use hardcoded fallback rules
FOOD_SAFETY_SHEET_URL=https://docs.google.com/spreadsheets/d/12J9CRkTpDJ4boKClVaz0qiev9KV7dEyr-TK4KA1ugJs/edit?usp=sharing
FOOD_SAFETY_RULE_SHEET_NAME=Thresholds_SOP

# Comma-separated WhatsApp chat IDs (phone or group ID) allowed to send images.
# In FOOD_SAFETY_TEST_MODE=true, leave empty to block all image processing until
# a separate test chat/group ID is explicitly added.
# In FOOD_SAFETY_TEST_MODE=false, an empty value allows all chats.
FOOD_SAFETY_ALLOWED_CHAT_IDS=

# How to handle PASS results:
#   warning_only  — only warn on FAIL / NEEDS_REVIEW; log PASS silently (default)
#   always_reply — reply PASS confirmation to group as well
FOOD_SAFETY_REPLY_MODE=warning_only

# Vision API endpoint for image OCR/temperature extraction.
# If unset, analyzer returns NEEDS_REVIEW for every image (safe fallback).
# Supports OpenAI Vision, Azure Vision, or any OpenAI-compatible vision endpoint.
VISION_API_URL=
VISION_API_KEY=
VISION_MODEL=gpt-4o

# ── Google Sheet Daily Log Writer ─────────────────────────
# Keep disabled until a separate WhatsApp test group has passed end-to-end.
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-service-account.json
FOOD_SAFETY_LOG_SHEET_URL=https://docs.google.com/spreadsheets/d/1x_AhaoZhYgBX2zWOx6z78B9Fi8mcbaw4jZUq_PhSlnE/edit?usp=sharing
FOOD_SAFETY_LOG_SPREADSHEET_ID=1x_AhaoZhYgBX2zWOx6z78B9Fi8mcbaw4jZUq_PhSlnE
FOOD_SAFETY_DAILY_LOG_SHEET_URL=
FOOD_SAFETY_DAILY_LOG_SPREADSHEET_ID=
FOOD_SAFETY_WRITE_MODE=test_only
FOOD_SAFETY_TEST_TAB=WhatsApp_AI_Daily_Log
FOOD_SAFETY_STORE_TABS=Rim,Stone Oak,Bandera
FOOD_SAFETY_NEEDS_REVIEW_TAB=Needs_Review

# ── Broth Count Command ────────────────────────────────────────────────────────
# Tab name in the Google Sheet containing the broth item list
BROTH_ITEM_SOURCE_SHEET=Daily_Entry_Template
# Column containing item names (B = second column)
BROTH_ITEM_SOURCE_COLUMN=B
# First row of item names (header rows above this are skipped)
BROTH_ITEM_SOURCE_START_ROW=11
# Optional: separate spreadsheet ID for broth items (defaults to FOOD_SAFETY_LOG_SPREADSHEET_ID)
BROTH_ITEM_SPREADSHEET_ID=
# Tab name for writing broth count log entries
BROTH_LOG_TAB=Broth_Count_Log
# Warning threshold for unusually high counts
BROTH_HIGH_COUNT_THRESHOLD=250

# ── Dynamic Template Architecture ─────────────────────────────────────────────
# Google Sheet tab containing the daily entry template
TEMPLATE_SHEET=Daily_Entry_Template
# Optional: separate spreadsheet ID (defaults to FOOD_SAFETY_LOG_SPREADSHEET_ID)
TEMPLATE_SPREADSHEET_ID=
# Column letters for item data in the template tab
TEMPLATE_NAME_COL=B
TEMPLATE_MIN_COL=C
TEMPLATE_MAX_COL=D
# First data row (rows before this are headers)
TEMPLATE_START_ROW=11
# Sync interval in milliseconds (default 5 minutes)
TEMPLATE_SYNC_INTERVAL_MS=300000

# ── Dashboard External Links ───────────────────────────────────────────────────
# URL for "Open Daily Entry Template" dashboard button
TEMPLATE_SHEET_URL=https://docs.google.com/spreadsheets/d/SHEET_ID/edit#gid=TAB_ID
# URL for "Open Daily Log" dashboard button  
LOG_SHEET_URL=https://docs.google.com/spreadsheets/d/1x_AhaoZhYgBX2zWOx6z78B9Fi8mcbaw4jZUq_PhSlnE/edit

# ── Agent Session / Group Quiet Mode ──────────────────────────────────────────
# Silence bot in groups unless /ldagent or wake command is sent
GROUP_QUIET_MODE=true
# Comma-separated commands that wake the bot in quiet mode
GROUP_WAKE_COMMANDS=/ldagent,/help,/status,/template,/log
# What to do when a non-session-owner sends a message during an active session
# Options: silent | minimal_warning
NON_OWNER_REPLY_MODE=silent
# Session idle timeout (minutes)
SESSION_TIMEOUT_MINUTES=5
# Send farewell message on session timeout
SESSION_END_MESSAGE_ENABLED=true
# Process food-safety images passively even without an active session
PASSIVE_IMAGE_MONITORING=false

# ── Multi-store WhatsApp Group Mapping ───────────────────────────────────────
# Fixed group → store mapping. In mapped groups, the bot never guesses store
# from group name or message text. Format: chat_id=store_id comma-separated.
# Valid store_id values: stone_oak, bandera, rim
STORE_GROUP_MAPPINGS=
STONE_OAK_GROUP_CHAT_ID=
BANDERA_GROUP_CHAT_ID=
RIM_GROUP_CHAT_ID=

# ── Manager Alert Group ──────────────────────────────────────────────────────
# Sends manager alerts after CONFIRM when Daily Entry values fail Min/Max.
MANAGER_ALERTS_ENABLED=true
MANAGER_ALERT_GROUP_CHAT_ID=
MANAGER_ALERT_LEVELS=FAIL,DANGER
MANAGER_ALERT_DEBOUNCE_MINUTES=5

# ── Vision AI (Phase 2A) ─────────────────────────────────────────────────────
# Enable vision-based incident detection and photo cross-check
VISION_ENABLED=true
# Vision provider: gemini | openai (uses VISION_API_KEY + VISION_MODEL above)
VISION_PROVIDER=gemini
# Gemini API key (only needed if VISION_PROVIDER=gemini)
GEMINI_API_KEY=
# Minimum confidence to auto-detect incidents (0.0–1.0)
VISION_CONFIDENCE_THRESHOLD=0.75
# Test mode — restricts to test groups only
VISION_TEST_MODE=true

# ── Incident Reports (Phase 2A — Part A) ─────────────────────────────────────
# Google Sheet tab for incident log entries
INCIDENT_LOG_TAB=Incident_Log

# ── Photo Audit / Compliance (Phase 2A — Part B) ─────────────────────────────
# Enable random photo verification after daily entry CONFIRM
PHOTO_AUDIT_ENABLED=true
# Probability of triggering a random photo audit (0.0–1.0)
PHOTO_AUDIT_RATE=0.20
# Max items to audit per submission
PHOTO_AUDIT_MAX_ITEMS=2
# Minutes before photo audit expires
PHOTO_AUDIT_TIMEOUT_MINUTES=10
# Temperature tolerance in °F (difference <= this = PASS)
TEMP_TOLERANCE_F=2

# ════════════════════════════════════════════════════════════════════════════
# Historical Log Access + Permissions (CEO Directive)
# ════════════════════════════════════════════════════════════════════════════

# Admin WhatsApp IDs — full history, all stores, exports
ADMIN_WHATSAPP_IDS=

# Manager WhatsApp IDs — store-level history, daily/weekly summary
MANAGER_WHATSAPP_IDS=

# ════════════════════════════════════════════════════════════════════════════
# Weekly Compliance Report
# Sent to manager alert group every week
# ════════════════════════════════════════════════════════════════════════════

# Enable weekly compliance report
WEEKLY_REPORT_ENABLED=false

# Day to send report (SUNDAY, MONDAY, ..., SATURDAY)
WEEKLY_REPORT_DAY=SUNDAY

# Time to send report (24-hour format, default 20:00 = 8 PM)
WEEKLY_REPORT_TIME=20:00
# Google Sheet tab for photo audit log
PHOTO_AUDIT_LOG_TAB=Photo_Audit_Log

# ════════════════════════════════════════════════════════════════════════════
# YoLink Sensor Integration (Phase 1.2C)
# Requires YoLink Hub + YoLink Developer Portal registration.
# If not configured, system continues with human-only workflow.
# ════════════════════════════════════════════════════════════════════════════

# Enable YoLink polling — set to true only after credentials are configured
YOLINK_ENABLED=false

# YoLink Developer Portal credentials (UAC app)
# Get these from: https://www.yosmart.com/ → Developer Portal → UAC App
YOLINK_CLIENT_ID=
YOLINK_CLIENT_SECRET=

# Polling interval in seconds (default: 300 = 5 minutes)
YOLINK_POLL_INTERVAL_SECONDS=300

# API call timeout in seconds
YOLINK_TIMEOUT_SECONDS=20

# ════════════════════════════════════════════════════════════════════════════
# Sensor Threshold Validation (Phase 1.2E)
# ════════════════════════════════════════════════════════════════════════════

# Minutes without a reading before marking sensor STALE
SENSOR_STALE_MINUTES=15

# Minutes without a reading before marking sensor OFFLINE
SENSOR_OFFLINE_MINUTES=60

# ════════════════════════════════════════════════════════════════════════════
# Sensor Alerts (Phase 1.2F)
# ════════════════════════════════════════════════════════════════════════════

# Enable sensor temperature alerts (WhatsApp store + manager group)
SENSOR_ALERTS_ENABLED=true

# Send first alert after sensor has been out of range for this many minutes
SENSOR_ALERT_AFTER_MINUTES=5

# Repeat alert interval (prevents spam — no repeat alerts within this window)
SENSOR_ALERT_REPEAT_MINUTES=30

# ════════════════════════════════════════════════════════════════════════════
# Human vs Sensor Cross-Validation (Phase 1.3)
# ════════════════════════════════════════════════════════════════════════════

# Enable cross-validation of human entries against YoLink readings
SENSOR_HUMAN_COMPARE_ENABLED=true

# Time window (minutes) to look back for matching sensor reading
SENSOR_MATCH_WINDOW_MINUTES=10

# Temperature difference (°F) within which human+sensor are considered MATCH
SENSOR_HUMAN_TOLERANCE_F=2

# ════════════════════════════════════════════════════════════════════════════
# Agent/MI Command Routing (CEO Directive)
# ════════════════════════════════════════════════════════════════════════════

# URLs for Agent-Coding and Mi-Core endpoints (no trailing slash)
AGENT_CODING_URL=http://localhost:3100
MI_CORE_URL=http://localhost:3200

# API keys for forwarding to Agent-Coding and Mi-Core
# These are set once per project. Raw keys shown only at creation.
AGENT_CODING_API_KEY=
MI_CORE_API_KEY=

# WhatsApp context cache directory (for Mi-Core chat context)
WHATSAPP_CONTEXT_CACHE_DIR=.local-agent-global/connectors/whatsapp

# Rate limits per client (messages per minute)
AGENT_CODING_RATE_LIMIT=120
MI_CORE_RATE_LIMIT=60

# ════════════════════════════════════════════════════════════════════════════
# Auto-Updater
# ════════════════════════════════════════════════════════════════════════════

UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/liemdo28/bakudan-releases/main/update-manifest.json
UPDATE_CHECK_INTERVAL_HOURS=6
