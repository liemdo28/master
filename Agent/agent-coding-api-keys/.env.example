# Universal AI Provider Manager
PORT=3456
HOST=127.0.0.1
CONFIG_PATH=./keys.json
REQUEST_TIMEOUT_MS=120000
HEALTH_INTERVAL_MS=60000
ROUTER_MODE=fallback
ACTIVE_PROVIDERS=opusmax,antigravity,openrouter,anthropic,openai,gemini,deepseek,ollama

# Per-provider values are optional. keys.json can store local secrets too.
# Never commit real keys.
OPUSMAX_BASE_URL=https://opusmax.shop/v1
OPUSMAX_DEFAULT_MODEL=claude-opus-4.7
OPUSMAX_API_KEYS=

ANTIGRAVITY_BASE_URL=https://api.nkq.vn/v1
ANTIGRAVITY_DEFAULT_MODEL=claude-opus-4
ANTIGRAVITY_API_KEYS=

ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-1-20250805
ANTHROPIC_API_KEYS=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-opus-4.1
OPENROUTER_API_KEYS=

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4.1
OPENAI_API_KEYS=

GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_DEFAULT_MODEL=gemini-2.5-pro
GEMINI_API_KEYS=

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_API_KEYS=

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b
