# ─────────────────────────────────────────────────────────────────────────────
# Antigravity Universal AI Gateway — IDE Integration Config
#
# HOW TO USE:
#   Copy these env vars into ~/Projects/agent-coding/.env (or export them in
#   your shell) to route the Antigravity IDE through the gateway.
#
#   The gateway handles: provider selection, failover, protocol translation,
#   tool-use normalization, streaming, and health monitoring.
#
#   The IDE code DOES NOT change. Only environment variables change.
#
# ARCHITECTURE:
#   Antigravity IDE  →  gateway (localhost:3456)  →  providers
#   agent-coding/       agent-coding-api-keys/        opusmax / antigravity / anthropic / ...
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway endpoint ──────────────────────────────────────────────────────────
GATEWAY_URL=http://127.0.0.1:3456

# ── Redirect OpusMax through the gateway ─────────────────────────────────────
# The IDE's ProviderRouter reads OPUSMAX_BASE_URL. Point it at the gateway's
# OpenAI-compatible endpoint and use any non-empty string as the API key.
OPUSMAX_BASE_URL=http://127.0.0.1:3456/v1
OPUSMAX_API_KEY=proxy
OPUSMAX_DEFAULT_MODEL=claude-opus-4-7

# ── Redirect Anthropic/Antigravity through the gateway ────────────────────────
ANTHROPIC_BASE_URL=http://127.0.0.1:3456
ANTHROPIC_API_KEY=proxy
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7

# Antigravity NKQ proxy — now routed via gateway
ANTIGRAVITY_BASE_URL=http://127.0.0.1:3456/v1
ANTIGRAVITY_API_KEY=proxy
ANTIGRAVITY_DEFAULT_MODEL=claude-opus-4-7

# ── Redirect OpenAI through the gateway ──────────────────────────────────────
OPENAI_BASE_URL=http://127.0.0.1:3456/v1
OPENAI_API_KEY=proxy
OPENAI_DEFAULT_MODEL=gpt-4.1

# ── Redirect OpenRouter through the gateway ───────────────────────────────────
OPENROUTER_BASE_URL=http://127.0.0.1:3456/v1
OPENROUTER_API_KEY=proxy

# ── Ollama stays local (gateway has its own Ollama routing) ──────────────────
# Leave OLLAMA_BASE_URL as-is; the gateway routes ollama: models to localhost:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ─────────────────────────────────────────────────────────────────────────────
# ISOLATION GUARANTEE:
#   The IDE does not know it's talking to a gateway. It sends normal API calls.
#   The gateway transparently handles protocol translation, failover, and logging.
#   If the gateway is down, set the vars back to their original values — zero
#   IDE code changes required in either direction.
# ─────────────────────────────────────────────────────────────────────────────
