{
  "name": "antigravity-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Antigravity Universal AI Gateway — protocol-aware multi-provider routing with Anthropic/OpenAI bridging",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "check": "tsc --noEmit",
    "health": "curl -s http://127.0.0.1:${PORT:-3456}/health | jq",
    "test:chat": "curl -s -X POST http://127.0.0.1:${PORT:-3456}/v1/chat/completions -H 'Content-Type: application/json' -H 'Authorization: Bearer proxy' -d '{\"model\":\"claude-opus-4-7\",\"messages\":[{\"role\":\"user\",\"content\":\"Reply exactly: OK\"}],\"max_tokens\":16}' | jq",
    "test:compat": "tsx src/tests/compatibility/run-tests.ts",
    "test:cline": "tsx src/tests/compatibility/run-tests.ts cline",
    "test:claude-code": "tsx src/tests/compatibility/run-tests.ts claude-code",
    "test:continue": "tsx src/tests/compatibility/run-tests.ts continue",
    "test:roocode": "tsx src/tests/compatibility/run-tests.ts roocode",
    "test:chaos": "tsx -e \"import{runChaosTests}from'./src/tests/chaos/chaos-runner.js';runChaosTests('http://127.0.0.1:3456').then(s=>{console.log(JSON.stringify(s,null,2));process.exit(s.failCount>0?1:0)})\"",
    "logs": "curl -s http://127.0.0.1:${PORT:-3456}/api/logs/structured | jq",
    "metrics": "curl -s http://127.0.0.1:${PORT:-3456}/api/metrics | jq",
    "docker:build": "docker build -t antigravity-gateway:latest .",
    "docker:run": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f gateway"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}