{
  "version": "1.0.0",
  "description": "Validation Registry for Agent OS",
  "validators": {
    "api-proxy": {
      "name": "api-proxy",
      "description": "Validates API Proxy service",
      "runner": "runners/api-proxy.js",
      "checks": ["process", "port", "health"],
      "config": {
        "processName": "node.exe",
        "port": 3456,
        "healthUrl": "http://127.0.0.1:3456/health",
        "startScript": "E:\\Project\\Master\\Agent\\agent-coding-api-keys\\start-proxy-background.ps1"
      }
    },
    "antigravity": {
      "name": "antigravity",
      "description": "Validates Antigravity IDE",
      "runner": "runners/antigravity.js",
      "checks": ["process", "window"],
      "config": {
        "processName": "Antigravity IDE"
      }
    },
    "cline": {
      "name": "cline",
      "description": "Validates Cline integration",
      "runner": "runners/cline.js",
      "checks": ["process", "command"],
      "config": {
        "processName": "code"
      }
    },
    "worker": {
      "name": "worker",
      "description": "Validates Worker service",
      "runner": "runners/worker.js",
      "checks": ["process", "port", "health"],
      "config": {
        "processName": "node.exe",
        "port": null,
        "healthUrl": null,
        "note": "Agent worker has no HTTP listener; validate through Agent OS control-plane worker API."
      }
    }
  }
}
