# Database
DATABASE_URL=file:./data/video-guide.db

# API Server
PORT=3001
API_BASE_URL=http://localhost:3001

# Admin Dashboard  
ADMIN_URL=http://localhost:5173

# Playwright Runner
PLAYWRIGHT_WORKERS=1
PLAYWRIGHT_TIMEOUT=120000
ALLOWED_DOMAINS=preview.bakudanramen.com,staging.example.com,localhost

# AI / Narration
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# TTS
TTS_PROVIDER=edge
EDGE_TTS_VOICE=en-US-AriaNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# Storage
STORAGE_BASE=d:/Project/Master/ai-video-guide-system/storage

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Privacy
ENABLE_PRIVACY_BLUR=true
PRIVACY_BLUR_RADIUS=20

# Admin Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123!
SESSION_SECRET=change-me-in-production
