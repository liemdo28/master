{
  "$id": "decision.schema.json",
  "type": "object",
  "required": ["priority", "impact_scores", "recommended_actions", "confidence"],
  "properties": {
    "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "impact_scores": {
      "type": "object",
      "properties": {
        "revenue": { "type": "number", "minimum": 0, "maximum": 1 },
        "operational": { "type": "number", "minimum": 0, "maximum": 1 },
        "customer": { "type": "number", "minimum": 0, "maximum": 1 },
        "compliance": { "type": "number", "minimum": 0, "maximum": 1 },
        "strategic": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "action"],
        "properties": {
          "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "action": { "type": "string" },
          "owner": { "type": "string" },
          "due_hint": { "type": "string" },
          "reversible": { "type": "boolean" }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reasoning": { "type": "string" }
  }
}
