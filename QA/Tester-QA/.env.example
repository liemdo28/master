# Tester-QA local QA/audit configuration
TESTER_QA_ENV=local
TESTER_QA_LOG_LEVEL=INFO

# Optional auth test credentials for local validation flows.
# Do not commit real secrets in .env.
TESTER_QA_USERNAME=
TESTER_QA_PASSWORD=

# Optional browser/runtime targets used by QA commands.
TESTER_QA_BASE_URL=http://localhost:3000
TESTER_QA_WEBSOCKET_URL=ws://localhost:3000/ws
