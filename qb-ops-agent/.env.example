# Agent Identity
AGENT_NAME=qb-ops-agent
AGENT_ENV=local

# API Endpoints
AGENT_OS_API_URL=http://127.0.0.1:3456/api
DASHBOARD_API_URL=https://dashboard.bakudanramen.com/api

# Machine Auth Token (generated on first run)
MACHINE_TOKEN=

# Local Database
LOCAL_DB_PATH=./data/qb-ops-agent.sqlite

# Timing
HEARTBEAT_INTERVAL_SECONDS=60
WORKFLOW_CHECK_INTERVAL_MINUTES=15

# Safety Flags (Phase 1: both must be false)
ENABLE_QB_WRITE_ACTIONS=false
ENABLE_SCREEN_AUTOMATION=false

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
